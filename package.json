{
  "name": "openexpense.org",
  "private": true,
  "scripts": {
    "clean:bundle": "node -e \"const fs=require('fs');for(const f of fs.readdirSync('.')){if(f==='app.js'||/^chunk-.*\\\\.js$/.test(f))fs.rmSync(f,{force:true});}\"",
    "build": "npm run clean:bundle && npx esbuild src/main.js --bundle --format=esm --minify --target=es2020 --splitting --outdir=. --entry-names=app --chunk-names=chunk-[hash]",
    "serve": "python3 -m http.server 8765"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8"
  }
}
